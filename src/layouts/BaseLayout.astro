---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';
import '../styles/global.css';
// Fonts self-hosted (DSGVO): kein Request an fonts.googleapis.com/gstatic.com
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  publishedDate?: Date;
  tags?: string[];
}

const {
  title,
  description = 'Homelab, Self-Hosting und AI Agents — Lars Meykel',
  ogType = 'website',
  publishedDate,
  tags = [],
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <Seo title={title} description={description} type={ogType} publishedDate={publishedDate} tags={tags} />
    <title>{title} · vugas.de</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="VUGAS.DE / LOG" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen">
    <Nav />
    <main class="mx-auto w-full max-w-[1280px] px-5 md:px-8 pt-8 pb-24">
      <slot />
    </main>
    <Footer />
  </body>
</html>
