---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toc from '../../components/Toc.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { id: post.id } }));
}

const { id } = Astro.params;
const posts = await getCollection('blog', entry => entry.id === id);
const post = posts[0];
if (!post) return Astro.redirect('/blog');

const { Content, headings, remarkPluginFrontmatter } = await render(post);
const minutesRead = remarkPluginFrontmatter.minutesRead ?? 1;
const formattedDate = post.data.date.toLocaleDateString('de-DE', {
  year: 'numeric', month: 'long', day: 'numeric'
});
const isoDate = post.data.date.toISOString().slice(0, 10);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedDate={post.data.date}
  tags={post.data.tags}
>

  <nav class="pt-4 mb-10 flex items-center gap-3 text-[0.68rem] tracking-[0.14em] uppercase"
       style="font-family: var(--font-display)">
    <a href="/blog" class="text-(--color-muted) hover:text-(--color-accent) transition-colors">&larr; Log</a>
    <span class="text-(--color-border-strong)">/</span>
    <span class="text-(--color-muted-deep)">{isoDate}</span>
  </nav>

  <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-10">

    <!-- Sidebar TOC -->
    <aside class="hidden md:block">
      <Toc headings={headings} />
    </aside>

    <!-- Main content -->
    <article>
      <header class="mb-14 pb-10 border-b border-(--color-border)">
        <div class="rise rise-1 section-num mb-5 flex items-center gap-4">
          <span>{formattedDate.toUpperCase()}</span>
          <span class="text-(--color-border-strong)">/</span>
          <span>{minutesRead} min read</span>
        </div>
        <h1 class="rise rise-2 display-lg text-(--color-text)"
            style="font-size: clamp(2rem, 1.4rem + 2.6vw, 3.4rem);">
          {post.data.title}
        </h1>
        <p class="rise rise-3 text-(--color-text-soft) text-[0.98rem] leading-[1.65] max-w-[60ch] mt-6"
           style="font-family: var(--font-sans)">{post.data.description}</p>
        <div class="rise rise-4 flex flex-wrap gap-1.5 mt-6">
          {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </header>

      <div class="prose max-w-none">
        <Content />
      </div>
    </article>

  </div>
</BaseLayout>
