---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const groupedByYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.date.getFullYear();
  if (!groupedByYear.has(y)) groupedByYear.set(y, []);
  groupedByYear.get(y)!.push(p);
}
const years = [...groupedByYear.keys()].sort((a, b) => b - a);
---

<BaseLayout title="LOG" description="Posts über Homelab, Self-Hosting und AI Agents.">

  <header class="pt-6 md:pt-10 pb-16 border-b border-[--color-border]">
    <div class="rise rise-1 section-num mb-5">03 // TRANSMISSIONS / LOG</div>
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-9">
        <h1 class="rise rise-2 display-xl">
          Notes from the <span class="text-[--color-accent]">Lab</span>.
        </h1>
        <p class="rise rise-3 text-[--color-text-soft] text-[0.98rem] leading-[1.65] max-w-[62ch] mt-8"
           style="font-family: var(--font-sans)">
          Was funktioniert, was nicht, und warum. Manchmal ein Sprint, manchmal ein Essay.
        </p>
      </div>
      <aside class="col-span-12 md:col-span-3 md:pt-2">
        <div class="rise rise-4 grid grid-cols-2 md:grid-cols-1 gap-y-5">
          <dl class="stat"><dt>Entries</dt><dd>{posts.length.toString().padStart(2, '0')}</dd></dl>
          <dl class="stat"><dt>Years</dt><dd>{years.length.toString().padStart(2, '0')}</dd></dl>
        </div>
      </aside>
    </div>
  </header>

  {posts.length === 0 ? (
    <p class="text-[--color-muted] pt-14" style="font-family: var(--font-mono)">// no entries yet</p>
  ) : (
    <div class="space-y-14 pt-14">
      {years.map((y, yi) => (
        <section class={`rise rise-${Math.min(yi + 1, 6)}`}>
          <div class="rule mb-4"><span>{y} / {groupedByYear.get(y)!.length.toString().padStart(2, '0')}</span></div>
          <ul>
            {groupedByYear.get(y)!.map((p, i) => (
              <li>
                <a href={`/blog/${p.id}`} class="group grid grid-cols-[5rem_1fr_auto] items-baseline gap-5
                                                 py-5 border-t border-[--color-border]
                                                 transition-transform duration-200 hover:translate-x-2"
                   style="transition-timing-function: var(--ease-out); will-change: transform;">
                  <time class="text-[--color-muted-deep] text-[0.68rem] tracking-[0.14em] tabular-nums uppercase"
                        style="font-family: var(--font-mono)">
                    {String(i + 1).padStart(2, '0')} /&nbsp;
                    {p.data.date.toLocaleDateString('de-DE', { month: '2-digit', day: '2-digit' })}
                  </time>
                  <div>
                    <h3 class="text-[1rem] uppercase text-[--color-text-soft] group-hover:text-[--color-accent] transition-colors"
                        style="font-family: var(--font-display); letter-spacing: -0.02em; line-height: 1.15;">
                      {p.data.title}
                    </h3>
                    <p class="text-[0.85rem] text-[--color-muted] mt-2 max-w-[72ch] leading-[1.55]"
                       style="font-family: var(--font-sans)">{p.data.description}</p>
                    <div class="flex flex-wrap gap-1.5 mt-3">
                      {p.data.tags.slice(0, 5).map(t => <span class="tag">{t}</span>)}
                    </div>
                  </div>
                  <span class="text-[--color-muted-deep] group-hover:text-[--color-accent] transition-colors"
                        style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.14em;"
                        aria-hidden="true">&gt;&gt;</span>
                </a>
              </li>
            ))}
          </ul>
          <div class="border-b border-[--color-border]"></div>
        </section>
      ))}
    </div>
  )}
</BaseLayout>
