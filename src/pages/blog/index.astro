---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Posts über Homelab, Self-Hosting und AI Agents.">
  <p class="font-mono text-muted text-xs mb-2">// Blog</p>
  <h1 class="text-3xl font-bold text-text mb-8">Blog</h1>

  {posts.length === 0 ? (
    <p class="text-muted text-sm font-mono">// Noch keine Posts. Bald...</p>
  ) : (
    <div class="flex flex-col gap-4">
      {posts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          id={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  )}
</BaseLayout>
