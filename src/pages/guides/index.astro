---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const standalone = guides.filter(g => !g.data.series);

const seriesMap = new Map<string, typeof guides[0]>();
for (const g of guides.filter(g => g.data.series)) {
  const key = g.data.series!;
  const existing = seriesMap.get(key);
  if (!existing || (g.data.order ?? 0) < (existing.data.order ?? 0)) {
    seriesMap.set(key, g);
  }
}
const seriesEntries = [...seriesMap.values()];
---

<BaseLayout title="Guides" description="Anleitungen für Self-Hosting, Homelab und AI.">
  <header class="grid grid-cols-12 gap-6 pt-8 pb-16">
    <div class="col-span-12 md:col-span-8">
      <div class="rise rise-1 section-num mb-4">04 / Guides</div>
      <h1 class="rise rise-2 display-xl mb-6">Schritt für <span class="text-accent">Schritt</span>.</h1>
      <p class="rise rise-3 text-text-soft leading-relaxed max-w-[60ch]">
        Anleitungen zu Setups die ich selbst betreibe — getestet, dokumentiert, reproduzierbar.
      </p>
    </div>
  </header>

  <div class="space-y-16">
    {standalone.length > 0 && (
      <section class="rise rise-3">
        <div class="rule mb-6"><span>Einzelne Anleitungen · {standalone.length}</span></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {standalone.map(g => (
            <GuideCard title={g.data.title} description={g.data.description}
              difficulty={g.data.difficulty} id={g.id} tags={g.data.tags} />
          ))}
        </div>
      </section>
    )}

    {seriesEntries.length > 0 && (
      <section class="rise rise-4">
        <div class="rule mb-6"><span>Mehrteilige Serien · {seriesEntries.length}</span></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {seriesEntries.map(g => (
            <GuideCard title={g.data.series!} description={g.data.description}
              difficulty={g.data.difficulty} id={g.id} tags={g.data.tags} />
          ))}
        </div>
      </section>
    )}

    {guides.length === 0 && (
      <p class="text-muted" style="font-family: var(--font-mono)">// Guides werden geschrieben.</p>
    )}
  </div>
</BaseLayout>
