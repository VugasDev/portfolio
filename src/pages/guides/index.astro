---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const standalone = guides.filter(g => !g.data.series);

const seriesMap = new Map<string, typeof guides[0]>();
for (const g of guides.filter(g => g.data.series)) {
  const key = g.data.series!;
  const existing = seriesMap.get(key);
  if (!existing || (g.data.order ?? 0) < (existing.data.order ?? 0)) {
    seriesMap.set(key, g);
  }
}
const seriesEntries = [...seriesMap.values()];
---

<BaseLayout title="GUIDES" description="Anleitungen für Self-Hosting, Homelab und AI.">

  <header class="pt-6 md:pt-10 pb-16 border-b border-(--color-border)">
    <div class="rise rise-1 section-num mb-5">04 // MANUALS / GUIDES</div>
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-9">
        <h1 class="rise rise-2 display-xl">
          Step by <span class="text-(--color-accent)">Step</span>.
        </h1>
        <p class="rise rise-3 text-(--color-text-soft) text-[0.98rem] leading-[1.65] max-w-[62ch] mt-8"
           style="font-family: var(--font-sans)">
          Anleitungen zu Setups, die ich selbst betreibe &mdash; getestet, dokumentiert, reproduzierbar.
        </p>
      </div>
      <aside class="col-span-12 md:col-span-3 md:pt-2">
        <div class="rise rise-4 grid grid-cols-2 md:grid-cols-1 gap-y-5">
          <dl class="stat"><dt>Guides</dt><dd>{guides.length.toString().padStart(2, '0')}</dd></dl>
          <dl class="stat"><dt>Series</dt><dd>{seriesEntries.length.toString().padStart(2, '0')}</dd></dl>
        </div>
      </aside>
    </div>
  </header>

  <div class="space-y-16 pt-14">
    {standalone.length > 0 && (
      <section class="rise rise-1">
        <div class="rule mb-6"><span>STANDALONE / {standalone.length.toString().padStart(2, '0')}</span></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {standalone.map(g => (
            <GuideCard title={g.data.title} description={g.data.description}
              difficulty={g.data.difficulty} id={g.id} tags={g.data.tags} />
          ))}
        </div>
      </section>
    )}

    {seriesEntries.length > 0 && (
      <section class="rise rise-2">
        <div class="rule rule-accent mb-6"><span>SERIES / {seriesEntries.length.toString().padStart(2, '0')}</span></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {seriesEntries.map(g => (
            <GuideCard title={g.data.series!} description={g.data.description}
              difficulty={g.data.difficulty} id={g.id} tags={g.data.tags} />
          ))}
        </div>
      </section>
    )}

    {guides.length === 0 && (
      <p class="text-(--color-muted)" style="font-family: var(--font-mono)">// guides in progress</p>
    )}
  </div>
</BaseLayout>
