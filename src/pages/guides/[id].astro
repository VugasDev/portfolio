---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map(guide => ({ params: { id: guide.id } }));
}

const { id } = Astro.params;
const guides = await getCollection('guides');
const guide = guides.find(g => g.id === id);
if (!guide) return Astro.redirect('/guides');

const { Content } = await render(guide);

let chapters: typeof guides = [];
if (guide.data.series) {
  chapters = guides
    .filter(g => g.data.series === guide.data.series && !g.data.draft)
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
}
---

<BaseLayout title={guide.data.title} description={guide.data.description}>
  <nav class="pt-4 mb-10 text-[0.72rem] tracking-widest uppercase flex items-center gap-2 text-muted" style="font-family: var(--font-mono)">
    <a href="/guides" class="hover:text-accent transition-colors">← Guides</a>
    {guide.data.series && (
      <>
        <span class="text-muted-deep">/</span>
        <span>{guide.data.series}</span>
      </>
    )}
  </nav>

  <div class="grid grid-cols-12 gap-10">
    {chapters.length > 0 ? (
      <>
        <aside class="hidden md:block col-span-3 sticky top-20 self-start">
          <div class="rule mb-4"><span>Kapitel</span></div>
          <ol class="space-y-0.5">
            {chapters.map((ch, i) => (
              <li>
                <a
                  href={`/guides/${ch.id}`}
                  class:list={[
                    'group flex items-baseline gap-2.5 px-2 py-1.5 text-[0.82rem] transition-colors border-l',
                    ch.id === id
                      ? 'text-accent border-accent'
                      : 'text-muted border-transparent hover:text-text hover:border-border-strong',
                  ]}
                  style="font-family: var(--font-mono)"
                >
                  <span class="text-muted-deep tabular-nums w-5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <span>{ch.data.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </aside>

        <article class="col-span-12 md:col-span-9 prose prose-invert max-w-none
                        prose-headings:font-normal prose-a:text-accent prose-a:no-underline hover:prose-a:underline
                        prose-code:text-accent-soft">
          <header class="not-prose mb-10">
            <div class="rise rise-1 flex items-center gap-3 mb-3">
              <span class="tag tag-accent">{guide.data.difficulty}</span>
              <span class="section-num">Kapitel {(guide.data.order ?? 0)}</span>
            </div>
            <h1 class="rise rise-2 display-lg text-text mb-3" style="font-size: clamp(2rem, 1.4rem + 2vw, 2.8rem); line-height: 1.05">
              {guide.data.title}
            </h1>
            <p class="rise rise-3 text-text-soft leading-relaxed max-w-[60ch]">{guide.data.description}</p>
          </header>
          <Content />
        </article>
      </>
    ) : (
      <article class="col-span-12 md:col-span-8 md:col-start-3 prose prose-invert max-w-none
                      prose-headings:font-normal prose-a:text-accent prose-a:no-underline hover:prose-a:underline
                      prose-code:text-accent-soft">
        <header class="not-prose mb-10">
          <div class="rise rise-1 flex items-center gap-3 mb-3">
            <span class="tag tag-accent">{guide.data.difficulty}</span>
            <span class="section-num">Guide</span>
          </div>
          <h1 class="rise rise-2 display-lg text-text mb-3" style="font-size: clamp(2rem, 1.4rem + 2vw, 2.8rem); line-height: 1.05">
            {guide.data.title}
          </h1>
          <p class="rise rise-3 text-text-soft leading-relaxed max-w-[60ch]">{guide.data.description}</p>
        </header>
        <Content />
      </article>
    )}
  </div>
</BaseLayout>
