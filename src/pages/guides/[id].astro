---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map(guide => ({ params: { id: guide.id } }));
}

const { id } = Astro.params;
const guides = await getCollection('guides');
const guide = guides.find(g => g.id === id);
if (!guide) return Astro.redirect('/guides');

const { Content } = await render(guide);

let chapters: typeof guides = [];
if (guide.data.series) {
  chapters = guides
    .filter(g => g.data.series === guide.data.series && !g.data.draft)
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
}
---

<BaseLayout title={guide.data.title} description={guide.data.description}>

  <nav class="pt-4 mb-10 flex items-center gap-3 text-[0.68rem] tracking-[0.2em] uppercase"
       style="font-family: var(--font-mono)">
    <a href="/guides" class="text-[--color-muted] hover:text-[--color-accent] transition-colors">&lt;&lt; GUIDES</a>
    {guide.data.series && (
      <>
        <span class="text-[--color-border-strong]">/</span>
        <span class="text-[--color-muted-deep]">{guide.data.series}</span>
      </>
    )}
  </nav>

  <div class="grid grid-cols-12 gap-10">

    {chapters.length > 0 ? (
      <>
        <aside class="hidden md:block col-span-3 sticky top-20 self-start">
          <div class="rule mb-4"><span>Chapters</span></div>
          <ol class="border-t border-[--color-border]">
            {chapters.map((ch, i) => (
              <li class="border-b border-[--color-border]">
                <a
                  href={`/guides/${ch.id}`}
                  class:list={[
                    'group flex items-baseline gap-3 px-2 py-2.5 text-[0.78rem] uppercase',
                    'transition-[transform,color] duration-200 hover:translate-x-1.5',
                    ch.id === id
                      ? 'text-[--color-accent] bg-[--color-surface]'
                      : 'text-[--color-muted] hover:text-[--color-text]',
                  ]}
                  style="font-family: var(--font-mono); letter-spacing: 0.08em; transition-timing-function: var(--ease-out);"
                >
                  <span class="text-[--color-muted-deep] tabular-nums w-6 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <span class="truncate">{ch.data.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </aside>

        <article class="col-span-12 md:col-span-9 prose max-w-none">
          <header class="not-prose mb-12 pb-8 border-b border-[--color-border]">
            <div class="rise rise-1 flex items-center gap-3 mb-5">
              <span class="tag tag-accent">{guide.data.difficulty}</span>
              <span class="section-num">CHAPTER / {String(guide.data.order ?? 0).padStart(2, '0')}</span>
            </div>
            <h1 class="rise rise-2 display-lg text-[--color-text]"
                style="font-size: clamp(2rem, 1.4rem + 2.4vw, 3.2rem);">
              {guide.data.title}
            </h1>
            <p class="rise rise-3 text-[--color-text-soft] text-[0.98rem] leading-[1.65] max-w-[60ch] mt-6"
               style="font-family: var(--font-sans)">{guide.data.description}</p>
          </header>
          <Content />
        </article>
      </>
    ) : (
      <article class="col-span-12 md:col-span-8 md:col-start-3 prose max-w-none">
        <header class="not-prose mb-12 pb-8 border-b border-[--color-border]">
          <div class="rise rise-1 flex items-center gap-3 mb-5">
            <span class="tag tag-accent">{guide.data.difficulty}</span>
            <span class="section-num">&#91; GUIDE &#93;</span>
          </div>
          <h1 class="rise rise-2 display-lg text-[--color-text]"
              style="font-size: clamp(2rem, 1.4rem + 2.4vw, 3.2rem);">
            {guide.data.title}
          </h1>
          <p class="rise rise-3 text-[--color-text-soft] text-[0.98rem] leading-[1.65] max-w-[60ch] mt-6"
             style="font-family: var(--font-sans)">{guide.data.description}</p>
        </header>
        <Content />
      </article>
    )}
  </div>
</BaseLayout>
