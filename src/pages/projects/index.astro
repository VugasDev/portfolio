---
// src/pages/projects/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const byStatus = (status: string) =>
  allProjects.filter(p => p.data.status === status);

const active   = byStatus('aktiv');
const wip      = byStatus('in Arbeit');
const planning = byStatus('Planung');
const archived = byStatus('archiviert');
---

<BaseLayout title="Projekte" description="Alle Homelab-Projekte — Proxmox, Docker, AI Agents und mehr.">
  <p class="font-mono text-muted text-xs mb-2">// Projekte</p>
  <h1 class="text-3xl font-bold text-text mb-8">Projekte</h1>

  {active.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-mono text-green uppercase tracking-widest mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-green inline-block"></span> Aktiv
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {active.map(p => <ProjectCard {...p.data} />)}
      </div>
    </section>
  )}

  {wip.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-mono text-blue uppercase tracking-widest mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-blue inline-block"></span> In Arbeit
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {wip.map(p => <ProjectCard {...p.data} />)}
      </div>
    </section>
  )}

  {planning.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-mono text-purple uppercase tracking-widest mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-purple inline-block"></span> Planung
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {planning.map(p => <ProjectCard {...p.data} />)}
      </div>
    </section>
  )}

  {archived.length > 0 && (
    <section>
      <h2 class="text-xs font-mono text-muted uppercase tracking-widest mb-4">Archiviert</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {archived.map(p => <ProjectCard {...p.data} />)}
      </div>
    </section>
  )}
</BaseLayout>
