---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getCaseStudySlugs, detailHref, type Project } from '../lib/projects';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const recentProjects = (await getCollection('projects'))
  .filter(p => p.data.status === 'aktiv' || p.data.status === 'in Arbeit')
  .slice(0, 4);

// Detailseiten-Logik wie auf /projects (Substanz-Bedingung in src/lib/projects.ts).
const studySlugs = await getCaseStudySlugs();
const projectHref = (p: Project) => detailHref(p, studySlugs) ?? '/projects';

const featuredGuides = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const stack = [
  'Proxmox', 'Docker', 'OPNsense', 'IPsec',
  'n8n', 'Ollama', 'Jellyfin', 'Claude', 'MCP',
  'nginx', 'Astro', 'LXC',
];
---

<BaseLayout title="Lars Meykel Stuhlmacher — Homelab & Systemintegration" description="Portfolio von Lars Meykel Stuhlmacher: Homelab, Self-Hosting, Netzwerk-Segmentierung und AI Agents — dokumentiert zum Nachbauen.">

  <!-- ─── HERO ─── -->
  <section class="pt-6 md:pt-10 pb-16 border-b border-(--color-border)">

    <div class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr] gap-8 md:gap-10 items-center">
      <!-- Left: Kicker + H1 + Lead + Buttons -->
      <div>
        <div class="rise rise-1 section-num mb-4">Homelab &middot; Self-Hosting &middot; AI</div>

        <h1 class="rise rise-2 display-xl text-(--color-text) mb-6">
          Homelab,<br/>
          <span style="color: var(--color-accent)">documented.</span>
        </h1>

        <p class="rise rise-3 text-(--color-text-soft) leading-[1.65] max-w-[52ch] mb-8"
           style="font-family: var(--font-sans); font-size: 1rem;">
          Ich bin Lars, angehender Fachinformatiker f&uuml;r Systemintegration
          (Abschluss vsl. 2027). Ich baue Infrastruktur &mdash; Proxmox, Docker, OPNsense,
          AI-Agents &mdash; und schreibe auf, was funktioniert und was nicht.
        </p>

        <div class="rise rise-4 flex flex-wrap items-center gap-3">
          <a href="/projects" class="btn btn-primary">Projekte</a>
          <a href="/guides" class="btn">Guides</a>
          <a href="/about" class="arrow ml-2">
            <span>About</span>
            <span class="glyph">&rarr;</span>
          </a>
          <a href="/about#ki" class="arrow">
            <span>KI-Haltung</span>
            <span class="glyph">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Right: Glass Status Panel -->
      <aside class="rise rise-5">
        <div style="background: var(--color-glass); border: 1px solid var(--color-border-strong); border-radius: var(--radius-card); padding: 1.25rem;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; font-family: var(--font-display); font-size: 0.8rem; padding: 0.5rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.55; color: var(--color-text-soft);">System</span>
            <span class="live" style="font-size: 0.75rem;">ready</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; font-family: var(--font-display); font-size: 0.8rem; padding: 0.5rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.55; color: var(--color-text-soft);">Nodes</span>
            <span style="font-weight: 700; color: var(--color-text);">07</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; font-family: var(--font-display); font-size: 0.8rem; padding: 0.5rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.55; color: var(--color-text-soft);">VLANs</span>
            <span style="font-weight: 700; color: var(--color-text);">06</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; font-family: var(--font-display); font-size: 0.8rem; padding: 0.5rem 0;">
            <span style="font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.55; color: var(--color-text-soft);">Storage</span>
            <span style="font-weight: 700; color: var(--color-text);">18 TB</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ─── STACK STRIP ─── -->
  <section class="rise rise-6 py-8 border-b border-(--color-border)">
    <div class="flex flex-wrap gap-2">
      {stack.map(s => (
        <span class="chip">{s}</span>
      ))}
    </div>
  </section>

  <!-- ─── PROJECTS ─── -->
  <section class="py-16 border-b border-(--color-border)">
    <header class="flex items-end justify-between mb-10">
      <div class="flex items-baseline gap-4">
        <span class="section-num">01 //</span>
        <h2 class="display-lg">Active Projects</h2>
      </div>
      <a href="/projects" class="arrow"><span>All Projects</span><span class="glyph">&rarr;</span></a>
    </header>

    {recentProjects.length > 0 ? (
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {recentProjects.map(p => (
          <li>
            <a href={projectHref(p)} class="card block group h-full">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-[1.05rem] text-(--color-text) group-hover:text-(--color-accent) transition-colors"
                    style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em;">
                  {p.data.name}
                </h3>
                <span class="tag tag-accent whitespace-nowrap shrink-0">{p.data.status}</span>
              </div>
              <p class="text-[0.85rem] text-(--color-muted) leading-[1.55] max-w-[56ch] mb-4"
                 style="font-family: var(--font-sans)">{p.data.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {p.data.tags.slice(0, 5).map(t => <span class="tag">{t}</span>)}
              </div>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-(--color-muted)" style="font-family: var(--font-mono)">// no active projects</p>
    )}
  </section>

  <!-- ─── LOG + GUIDES ─── -->
  <section class="grid grid-cols-12 gap-10 pt-16">

    <div class="col-span-12 md:col-span-7">
      <header class="flex items-end justify-between mb-8">
        <div class="flex items-baseline gap-4">
          <span class="section-num">02 //</span>
          <h2 class="display-lg">Log</h2>
        </div>
        <a href="/blog" class="arrow"><span>All Entries</span><span class="glyph">&rarr;</span></a>
      </header>

      {recentPosts.length > 0 ? (
        <ul>
          {recentPosts.map((p, i) => (
            <li>
              <a href={`/blog/${p.id}`} class="row group">
                <time class="row-idx shrink-0 tabular-nums">
                  {String(i + 1).padStart(2, '0')} / {p.data.date.toLocaleDateString('de-DE', { year: '2-digit', month: '2-digit', day: '2-digit' })}
                </time>
                <span class="text-(--color-text-soft) group-hover:text-(--color-accent) transition-colors"
                      style="font-family: var(--font-sans)">{p.data.title}</span>
                <span class="row-idx" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-(--color-muted)" style="font-family: var(--font-mono)">// no entries yet</p>
      )}
    </div>

    <div class="col-span-12 md:col-span-5">
      <header class="flex items-end justify-between mb-8">
        <div class="flex items-baseline gap-4">
          <span class="section-num">03 //</span>
          <h2 class="display-lg">Guides</h2>
        </div>
        <a href="/guides" class="arrow"><span>All</span><span class="glyph">&rarr;</span></a>
      </header>

      {featuredGuides.length > 0 ? (
        <ul class="space-y-3">
          {featuredGuides.map(g => (
            <li>
              <a href={`/guides/${g.id}`} class="card block group">
                <div class="flex items-center justify-between mb-3">
                  <span class="tag">{g.data.difficulty}</span>
                  <span class="row-idx group-hover:text-(--color-accent) transition-colors" aria-hidden="true">&rarr;</span>
                </div>
                <h3 class="text-[0.92rem] text-(--color-text) group-hover:text-(--color-accent) transition-colors"
                    style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1;">
                  {g.data.title}
                </h3>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-(--color-muted)" style="font-family: var(--font-mono)">// no guides yet</p>
      )}
    </div>
  </section>

</BaseLayout>
