---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const recentProjects = (await getCollection('projects'))
  .filter(p => p.data.status === 'aktiv' || p.data.status === 'in Arbeit')
  .slice(0, 4);

const featuredGuides = (await getCollection('guides', ({ data }) => !data.draft))
  .slice(0, 3);

const stack = [
  { label: 'Proxmox',   kind: 'hyp' },
  { label: 'Docker',    kind: 'ctr' },
  { label: 'OPNsense',  kind: 'net' },
  { label: 'WireGuard', kind: 'vpn' },
  { label: 'n8n',       kind: 'auto' },
  { label: 'Ollama',    kind: 'ai' },
  { label: 'Jellyfin',  kind: 'media' },
  { label: 'Claude',    kind: 'ai' },
  { label: 'MCP',       kind: 'ai' },
];
---

<BaseLayout title="Home" description="Homelab, Self-Hosting und AI Agents — Lars Meykel">

  <!-- HERO: asymmetric 12-col -->
  <section class="grid grid-cols-12 gap-6 md:gap-10 pt-8 md:pt-20 pb-20">
    <div class="col-span-12 md:col-span-8">
      <div class="rise rise-1 flex items-center gap-3 mb-6">
        <span class="live">SYSTEM READY</span>
        <span class="text-muted-deep text-[0.7rem]" style="font-family: var(--font-mono)">
          uptime · 412d
        </span>
      </div>

      <h1 class="rise rise-2 display-xl mb-6">
        Homelab,<br/>
        <span class="text-accent">dokumentiert</span><span class="cursor"></span>
      </h1>

      <p class="rise rise-3 text-text-soft text-[1.02rem] leading-relaxed max-w-[58ch] mb-10">
        Ich bin Lars. Ich baue Infrastruktur — Proxmox, Docker, AI-Agents — und schreibe auf,
        was funktioniert und was nicht. Damit du es nachbauen kannst, ohne die Nacht zu verlieren.
      </p>

      <div class="rise rise-4 flex flex-wrap items-center gap-3">
        <a href="/projects" class="btn btn-primary">
          <span>Projekte</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/guides" class="btn">
          <span>Guides lesen</span>
        </a>
        <a href="/about" class="arrow ml-2">
          <span>über mich</span>
          <span class="glyph">↗</span>
        </a>
      </div>
    </div>

    <!-- Right rail: meta info, asymmetrisch -->
    <aside class="col-span-12 md:col-span-4 md:pt-4">
      <div class="rise rise-3 grid grid-cols-2 gap-x-6 gap-y-5">
        <dl class="stat">
          <dt>Standort</dt>
          <dd>DE · de</dd>
        </dl>
        <dl class="stat">
          <dt>Nodes</dt>
          <dd>7 lxc</dd>
        </dl>
        <dl class="stat">
          <dt>VLANs</dt>
          <dd>6</dd>
        </dl>
        <dl class="stat">
          <dt>Storage</dt>
          <dd>18 TB</dd>
        </dl>
      </div>
    </aside>
  </section>

  <!-- Stack: horizontale Zeile, kein Pill -->
  <section class="rise rise-5 mb-24">
    <div class="rule mb-4"><span>Stack</span></div>
    <ul class="flex flex-wrap gap-x-6 gap-y-2" style="font-family: var(--font-mono); font-size: 0.82rem">
      {stack.map((s, i) => (
        <li class="flex items-baseline gap-1.5">
          <span class="text-muted-deep text-[0.65rem]">{String(i + 1).padStart(2, '0')}</span>
          <span class="text-text-soft">{s.label}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- PROJECTS (ohne Card-Wrap drumherum) -->
  <section class="mb-24">
    <header class="flex items-end justify-between mb-8">
      <div class="flex items-baseline gap-3">
        <span class="section-num">01 /</span>
        <h2 class="display-lg">Projekte</h2>
      </div>
      <a href="/projects" class="arrow"><span>alle Projekte</span><span class="glyph">→</span></a>
    </header>

    {recentProjects.length > 0 ? (
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-[1px] bg-border">
        {recentProjects.map(p => (
          <li class="bg-bg">
            <a href={p.data.github ?? p.data.url ?? '/projects'} class="block p-5 md:p-6 h-full hover:bg-surface transition-colors duration-200">
              <div class="flex items-start justify-between gap-4">
                <h3 class="text-[1.05rem] text-text" style="font-family: var(--font-display)">{p.data.name}</h3>
                <span class="tag tag-accent whitespace-nowrap">{p.data.status}</span>
              </div>
              <p class="text-sm text-muted leading-relaxed mt-3 max-w-[60ch]">{p.data.description}</p>
              <div class="mt-5 flex flex-wrap gap-1.5">
                {p.data.tags.slice(0, 4).map(t => <span class="tag">{t}</span>)}
              </div>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-muted" style="font-family: var(--font-mono)">// Projekte folgen...</p>
    )}
  </section>

  <!-- BLOG + GUIDES nebeneinander, asymmetrisch 7/5 -->
  <section class="grid grid-cols-12 gap-10">
    <div class="col-span-12 md:col-span-7">
      <header class="flex items-end justify-between mb-6">
        <div class="flex items-baseline gap-3">
          <span class="section-num">02 /</span>
          <h2 class="display-lg">Blog</h2>
        </div>
        <a href="/blog" class="arrow"><span>alle Posts</span><span class="glyph">→</span></a>
      </header>
      {recentPosts.length > 0 ? (
        <ul class="divide-y divide-border/70">
          {recentPosts.map(p => (
            <li>
              <a href={`/blog/${p.id}`} class="group flex items-baseline gap-4 py-3.5 hover:text-accent transition-colors">
                <time class="shrink-0 text-muted-deep text-[0.7rem] tabular-nums w-20" style="font-family: var(--font-mono)">
                  {p.data.date.toLocaleDateString('de-DE', { year: '2-digit', month: '2-digit', day: '2-digit' })}
                </time>
                <span class="text-text-soft group-hover:text-accent transition-colors">{p.data.title}</span>
                <span class="ml-auto text-muted-deep text-xs group-hover:text-accent transition-colors" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted" style="font-family: var(--font-mono)">// kein Post bisher.</p>
      )}
    </div>

    <div class="col-span-12 md:col-span-5">
      <header class="flex items-end justify-between mb-6">
        <div class="flex items-baseline gap-3">
          <span class="section-num">03 /</span>
          <h2 class="display-lg">Guides</h2>
        </div>
        <a href="/guides" class="arrow"><span>alle</span><span class="glyph">→</span></a>
      </header>
      {featuredGuides.length > 0 ? (
        <ul class="space-y-3">
          {featuredGuides.map(g => (
            <li>
              <a href={`/guides/${g.id}`} class="card block group">
                <div class="flex items-center justify-between mb-2">
                  <span class="tag">{g.data.difficulty}</span>
                  <span class="text-muted-deep text-xs group-hover:text-accent transition-colors" aria-hidden="true">↗</span>
                </div>
                <h3 class="text-sm text-text group-hover:text-accent transition-colors" style="font-family: var(--font-display)">
                  {g.data.title}
                </h3>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted" style="font-family: var(--font-mono)">// kein Guide bisher.</p>
      )}
    </div>
  </section>

</BaseLayout>
