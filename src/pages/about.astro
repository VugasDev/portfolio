---
import BaseLayout from '../layouts/BaseLayout.astro';

const facts = [
  ['Role',       'Fachinformatiker Systemintegration (i.&thinsp;A.)'],
  ['Ausbildung', '2. Lehrjahr &middot; AP1: 87 Pkt. &middot; Abschluss vsl. 2027'],
  ['Studium',    'Bachelor Professional in IT (IHK) &mdash; ab 09/2026'],
  ['Zertifikate','KMK-Fremdsprachenzertifikat Englisch C1 &middot; Cisco CCNA (in Vorbereitung)'],
  ['Location',   'Duisburg, Deutschland'],
  ['Stack',      'Proxmox / Docker / OPNsense'],
  ['Contact',    'contact@vugas.de'],
  ['Status',     'Offen f&uuml;r Junior-Positionen ab Abschluss'],
  ['Unterlagen', 'Vollst&auml;ndige Bewerbungsunterlagen auf Anfrage'],
];

const nowItems = [
  'Mediastack: NVIDIA-Treiber auf dem Host, NVENC f&uuml;r Jellyfin-Transcoding aktivieren',
  'Paperless: RAG-Chatbot &uuml;ber alle Dokumente, Migration auf Mistral',
  'Portfolio mit Guides &amp; Blogposts f&uuml;llen &mdash; weniger halbfertige Drafts',
];

const builds = [
  ['INFRA',  'Proxmox-Hypervisor, VLANs, Zero-Trust-Firewall via OPNsense, IPsec Site-to-Site (IKEv2).'],
  ['MEDIA',  'Jellyfin-Medienserver mit *arr-Automatisierung &mdash; Metadaten, Untertitel (Bazarr), reproduzierbare Qualit&auml;tsprofile (Recyclarr), Transcoding.'],
  ['AUTO',   'n8n-Workflows, lokale AI-Agenten via Ollama, Claude API f&uuml;r komplexere Tasks.'],
  ['TOOLS',  'Eigene MCP-Server f&uuml;r Claude Code, CLI-Tools, kleine Dashboards.'],
];
---

<BaseLayout title="Über mich — Lars Meykel Stuhlmacher" description="Fachinformatiker Systemintegration (Ausbildung, Abschluss 2027). Wer ich bin, was ich baue und wie ich mit KI arbeite.">

  <header class="pt-6 md:pt-10 pb-16 border-b border-(--color-border)">
    <div class="rise rise-1 section-num mb-5">05 // OPERATOR / PROFILE</div>
    <div class="grid grid-cols-12 gap-6 md:gap-10">
      <div class="col-span-12 md:col-span-8">
        <h1 class="rise rise-2 display-xl">
          Lars Meykel<br/><span style="color: var(--color-accent);">Stuhlmacher</span>.
        </h1>
        <p class="rise rise-3 text-(--color-text-soft) text-[0.98rem] leading-[1.65] max-w-[62ch] mt-8"
           style="font-family: var(--font-sans)">
          Nach abgeschlossener Ausbildung zum Fachinformatiker f&uuml;r Anwendungsentwicklung
          mache ich aktuell meine zweite Ausbildung: Fachinformatiker f&uuml;r Systemintegration
          (2.&nbsp;Lehrjahr, Abschluss vsl. 2027) &mdash; Administration und Entwicklung aus einer
          Hand. Parallel bereite ich mich auf den Cisco CCNA vor. Was ich im Beruf lerne, vertiefe
          ich zuhause: Seit Jahren baue und betreibe ich eine eigene Infrastruktur &mdash; von
          VLAN-Segmentierung bis zum AI-Agenten-System &mdash; und schreibe dabei alles auf,
          damit andere es nachbauen k&ouml;nnen.
        </p>
      </div>

      <aside class="col-span-12 md:col-span-4 md:pt-3">
        <div class="rise rise-4 rule mb-5"><span>File</span></div>
        <dl class="rise rise-5 grid grid-cols-[auto_1fr] gap-x-5 gap-y-3.5"
            style="font-family: var(--font-mono)">
          {facts.map(([k, v]) => (
            <>
              <dt class="text-(--color-muted-deep) text-[0.64rem] tracking-[0.18em] uppercase pt-0.5">{k}</dt>
              <dd class="text-(--color-text-soft) text-[0.82rem] leading-snug" set:html={v}></dd>
            </>
          ))}
        </dl>
      </aside>
    </div>
  </header>

  <section class="grid grid-cols-12 gap-10 py-16 border-b border-(--color-border)">
    <div class="col-span-12 md:col-span-7">
      <div class="rule mb-6"><span>What I Build</span></div>
      <ul>
        {builds.map(([k, v]) => (
          <li class="grid grid-cols-[6rem_1fr] gap-5 py-4 border-t border-(--color-border)">
            <span class="text-(--color-accent) text-[0.68rem] tracking-[0.22em] uppercase pt-1"
                  style="font-family: var(--font-mono)">{k}</span>
            <p class="text-(--color-text-soft) leading-[1.6] text-[0.9rem]"
               style="font-family: var(--font-sans)" set:html={v}></p>
          </li>
        ))}
      </ul>
      <div class="border-b border-(--color-border)"></div>
    </div>

    <div class="col-span-12 md:col-span-5">
      <div class="rule rule-accent mb-6"><span>/NOW</span></div>
      <ul>
        {nowItems.map((n, i) => (
          <li class="flex items-baseline gap-4 py-3 border-t border-(--color-border)">
            <span class="text-(--color-muted-deep) text-[0.66rem] tabular-nums tracking-[0.1em] shrink-0"
                  style="font-family: var(--font-mono)">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-(--color-text-soft) text-[0.9rem] leading-[1.55]"
                  style="font-family: var(--font-sans)" set:html={n}></span>
          </li>
        ))}
      </ul>
      <div class="border-b border-(--color-border)"></div>
    </div>
  </section>

  <section id="ki" class="py-16 border-b border-(--color-border) scroll-mt-24">
    <div class="rule rule-accent mb-8"><span>/AI</span></div>
    <div class="grid grid-cols-12 gap-6 md:gap-10">
      <div class="col-span-12 md:col-span-8">
        <h2 class="display-lg mb-8" style="max-width: 16ch;">
          Wie ich mit <span style="color: var(--color-accent);">KI</span> arbeite.
        </h2>
        <div class="space-y-5 text-(--color-text-soft) text-[0.96rem] leading-[1.7] max-w-[64ch]"
             style="font-family: var(--font-sans)">
          <p>
            KI ist für mich ein Hebel, kein Autopilot. Ich delegiere damit Arbeit, nicht das
            Denken — Architektur, Entscheidungen und die Verantwortung fürs Ergebnis bleiben bei
            mir. Wo es geht, läuft sie lokal im eigenen Netz; Cloud-Modelle setze ich gezielt dort
            ein, wo sie den Unterschied machen, ohne meine Daten aus der Hand zu geben. Weder Hype
            noch Reflex-Nein: ich prüfe, wo KI echten Wert schafft, und durchschaue den Rest. So
            baue ich mehr und lerne schneller — und bleibe die Person, die versteht, was sie
            ausliefert.
          </p>
          <p>
            Beim Code gilt das doppelt. Code, Text und Config mit KI zu generieren, ist ein
            enormer Beschleuniger — aber der Output ist ein Vorschlag, kein Ergebnis. Der
            Unterschied entscheidet sich an der Gegenprüfung: Vibe-Coding ohne Review produziert
            Tech-Debt und Sicherheitslücken, die erst im Betrieb auffallen; mit konsequentem
            Gegenlesen, Tests und einem echten Verständnis dafür, was der Code tut, wird dieselbe
            Geschwindigkeit zum verlässlichen Hebel. Ich lasse generieren — aber ich verantworte
            jede Zeile, als hätte ich sie selbst geschrieben.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-16 pb-10">
    <div class="rule mb-8"><span>Philosophy</span></div>
    <blockquote class="pl-0">
      <p class="display-lg"
         style="font-size: clamp(2.4rem, 1.6rem + 3.8vw, 4.2rem); line-height: 0.95; max-width: 22ch; color: var(--color-text);">
        Man lernt durch Bauen.<br/>Und dann durch <span style="color: var(--color-accent);">Aufschreiben</span>.
      </p>
    </blockquote>
  </section>

</BaseLayout>
