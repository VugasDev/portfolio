---
interface Props {
  name: string;
  description: string;
  details?: string;
  tags: string[];
  status: string;
  github?: string;
  url?: string;
  caseStudyHref?: string;
}
const { name, description, details, tags, status, github, url, caseStudyHref } = Astro.props;
---

<article class="card group flex flex-col gap-3">
  {/* Hover-Overlay deckt nur diesen Wrapper ab — die Link-Zeile
      (Case Study/GitHub/Live) darunter bleibt sichtbar und klickbar. */}
  <div class="relative flex-1 flex flex-col gap-3">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-[1.02rem] text-(--color-text) group-hover:text-(--color-accent) transition-colors"
          style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1;">
        {name}
      </h3>
      <span class="tag tag-accent whitespace-nowrap shrink-0">{status}</span>
    </div>

    <p class="text-[0.85rem] text-(--color-muted) leading-[1.55] max-w-[60ch]"
       style="font-family: var(--font-sans)">{description}</p>

    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>

    {details && (
      <div class:list={['card-readme', !(github || url || caseStudyHref) && 'card-readme-full']}>
        <span class="card-readme-kicker">{name}</span>
        <p>{details}</p>
      </div>
    )}
  </div>

  {(github || url || caseStudyHref) && (
    <div class="flex gap-5 mt-auto pt-3 border-t border-(--color-border)">
      {caseStudyHref && (
        <a href={caseStudyHref} class="arrow"><span>Case Study</span><span class="glyph">&rarr;</span></a>
      )}
      {github && (
        <a href={github} class="arrow"><span>GitHub</span><span class="glyph">&rarr;</span></a>
      )}
      {url && (
        <a href={url} class="arrow"><span>Live</span><span class="glyph">&rarr;</span></a>
      )}
    </div>
  )}
</article>
