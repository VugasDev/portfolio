---
interface Props {
  name: string;
  description: string;
  tags: string[];
  status: string;
  github?: string;
  url?: string;
}
const { name, description, tags, status, github, url } = Astro.props;
---

<article class="card group flex flex-col gap-3">
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-[1.02rem] text-text group-hover:text-accent transition-colors" style="font-family: var(--font-display)">
      {name}
    </h3>
    <span class="tag tag-accent whitespace-nowrap">{status}</span>
  </div>

  <p class="text-sm text-muted leading-relaxed max-w-[60ch]">{description}</p>

  <div class="flex flex-wrap gap-1.5 mt-1">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>

  {(github || url) && (
    <div class="flex gap-4 mt-auto pt-3 border-t border-border/60">
      {github && (
        <a href={github} class="arrow"><span class="glyph">↗</span><span>GitHub</span></a>
      )}
      {url && (
        <a href={url} class="arrow"><span class="glyph">↗</span><span>Live</span></a>
      )}
    </div>
  )}
</article>
