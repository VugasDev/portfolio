---
interface Props {
  name: string;
  description: string;
  details?: string;
  tags: string[];
  status: string;
  github?: string;
  url?: string;
  detailHref?: string;
  hasCaseStudy?: boolean;
}
const { name, description, details, tags, status, github, url, detailHref, hasCaseStudy } = Astro.props;
const moreLabel = hasCaseStudy ? 'Case Study lesen' : 'Mehr erfahren';
---

<article class="card group flex flex-col gap-3">
  {/* Hover-Overlay deckt nur diesen Wrapper ab — eine evtl. Link-Zeile
      (GitHub/Live) darunter bleibt sichtbar und klickbar. */}
  <div class="relative flex-1 flex flex-col gap-3">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-[1.02rem] text-(--color-text) group-hover:text-(--color-accent) transition-colors"
          style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1;">
        {name}
        {detailHref && (
          <span class="case-mark" title={hasCaseStudy ? 'Case Study verfügbar' : 'Mehr Details verfügbar'} aria-hidden="true">&#10022;</span>
        )}
      </h3>
      <span class="tag tag-accent whitespace-nowrap shrink-0">{status}</span>
    </div>

    <p class="text-[0.85rem] text-(--color-muted) leading-[1.55] max-w-[60ch]"
       style="font-family: var(--font-sans)">{description}</p>

    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>

    {details && (
      <div class:list={['card-readme', (detailHref || !(github || url)) && 'card-readme-full']}>
        <span class="card-readme-kicker">{name}</span>
        <p>{details}</p>
        {detailHref && (
          <span class="card-readme-more">{moreLabel} <span class="glyph">&rarr;</span></span>
        )}
      </div>
    )}
  </div>

  {/* Link-Zeile nur ohne Detailseite — sonst wohnen die Links dort. */}
  {(github || url) && !detailHref && (
    <div class="flex gap-5 mt-auto pt-3 border-t border-(--color-border)">
      {github && (
        <a href={github} class="arrow"><span>GitHub</span><span class="glyph">&rarr;</span></a>
      )}
      {url && (
        <a href={url} class="arrow"><span>Live</span><span class="glyph">&rarr;</span></a>
      )}
    </div>
  )}

  {/* Ganze Card klickbar, wenn eine Detailseite existiert (stretched link) */}
  {detailHref && (
    <a href={detailHref} class="absolute inset-0 z-10 rounded-[var(--radius-card)]"
       aria-label={`${moreLabel}: ${name}`}></a>
  )}
</article>
