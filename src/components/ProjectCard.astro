---
// src/components/ProjectCard.astro
interface Props {
  name: string;
  description: string;
  tags: string[];
  status: string;
  github?: string;
  url?: string;
}
const { name, description, tags, status, github, url } = Astro.props;

const statusColor: Record<string, string> = {
  'aktiv':     'text-green border-green/30 bg-green/10',
  'in Arbeit': 'text-blue border-blue/30 bg-blue/10',
  'Planung':   'text-purple border-purple/30 bg-purple/10',
  'archiviert':'text-muted border-muted/30 bg-muted/10',
};
---

<div class="bg-surface border border-border rounded-lg p-5 flex flex-col gap-3 hover:border-border-subtle transition-colors">
  <div class="flex items-start justify-between gap-2">
    <h3 class="text-sm font-semibold text-text">{name}</h3>
    <span class:list={['text-xs px-2 py-0.5 rounded-full border font-mono whitespace-nowrap', statusColor[status] ?? statusColor['archiviert']]}>
      {status}
    </span>
  </div>
  <p class="text-xs text-muted leading-relaxed">{description}</p>
  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => (
      <span class="text-xs font-mono text-blue-light bg-blue/10 border border-blue/20 px-2 py-0.5 rounded-full">{tag}</span>
    ))}
  </div>
  {(github || url) && (
    <div class="flex gap-3 mt-auto pt-2">
      {github && <a href={github} class="text-xs text-muted hover:text-blue font-mono no-underline">→ GitHub</a>}
      {url && <a href={url} class="text-xs text-muted hover:text-blue font-mono no-underline">→ Live</a>}
    </div>
  )}
</div>
