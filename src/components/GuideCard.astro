---
interface Props {
  title: string;
  description: string;
  difficulty: string;
  id: string;
  tags: string[];
}
const { title, description, difficulty, id, tags } = Astro.props;
---

<a href={`/guides/${id}`} class="card group block">
  <div class="flex items-center justify-between mb-3">
    <span class="section-num">GUIDE</span>
    <span class="tag tag-accent">{difficulty}</span>
  </div>

  <h3 class="text-[1rem] text-text group-hover:text-accent transition-colors mb-2" style="font-family: var(--font-display)">
    {title}
  </h3>

  <p class="text-sm text-muted leading-relaxed mb-4 max-w-[60ch]">{description}</p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</a>
