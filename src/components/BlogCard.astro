---
interface Props {
  title: string;
  description: string;
  date: Date;
  id: string;
  tags: string[];
}
const { title, description, date, id, tags } = Astro.props;
const formatted = date.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: '2-digit' });
---

<a href={`/blog/${id}`} class="card group block">
  <div class="flex items-center justify-between mb-3">
    <time class="text-muted-deep text-[0.7rem] tracking-widest uppercase" style="font-family: var(--font-mono)">
      {formatted}
    </time>
    <span class="text-muted-deep text-xs group-hover:text-accent transition-colors" aria-hidden="true">↗</span>
  </div>

  <h3 class="text-[1rem] text-text group-hover:text-accent transition-colors mb-2" style="font-family: var(--font-display)">
    {title}
  </h3>

  <p class="text-sm text-muted leading-relaxed mb-4 max-w-[60ch]">{description}</p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</a>
