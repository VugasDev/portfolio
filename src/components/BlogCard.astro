---
interface Props {
  title: string;
  description: string;
  date: Date;
  id: string;
  tags: string[];
}
const { title, description, date, id, tags } = Astro.props;
const formatted = date.toLocaleDateString('de-DE', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<a href={`/blog/${id}`} class="card group block">
  <div class="flex items-center justify-between mb-3">
    <time class="text-[--color-muted-deep] text-[0.66rem] tracking-[0.18em] uppercase tabular-nums"
          style="font-family: var(--font-mono)">
      {formatted}
    </time>
    <span class="text-[--color-muted-deep] text-[0.7rem] group-hover:text-[--color-accent] transition-colors"
          style="font-family: var(--font-mono); letter-spacing: 0.14em;" aria-hidden="true">&gt;&gt;</span>
  </div>

  <h3 class="text-[1.02rem] uppercase text-[--color-text] group-hover:text-[--color-accent] transition-colors mb-3"
      style="font-family: var(--font-display); letter-spacing: -0.02em; line-height: 1.15;">
    {title}
  </h3>

  <p class="text-[0.85rem] text-[--color-muted] leading-[1.55] mb-4 max-w-[60ch]"
     style="font-family: var(--font-sans)">{description}</p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</a>
