---
// src/components/BlogCard.astro
interface Props {
  title: string;
  description: string;
  date: Date;
  id: string;
  tags: string[];
}
const { title, description, date, id, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={`/blog/${id}`} class="block bg-surface border border-border rounded-lg p-5 hover:border-border-subtle transition-colors no-underline group">
  <p class="font-mono text-muted text-xs mb-1">{formattedDate}</p>
  <h3 class="text-sm font-semibold text-text group-hover:text-blue transition-colors mb-2">{title}</h3>
  <p class="text-xs text-muted leading-relaxed mb-3">{description}</p>
  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => (
      <span class="text-xs font-mono text-green bg-green/10 border border-green/20 px-2 py-0.5 rounded-full">{tag}</span>
    ))}
  </div>
</a>
