---
const navItems = [
  { href: '/',         label: 'Index',    num: '01' },
  { href: '/projects', label: 'Projects', num: '02' },
  { href: '/blog',     label: 'Log',      num: '03' },
  { href: '/guides',   label: 'Guides',   num: '04' },
  { href: '/about',    label: 'About',    num: '05' },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href));
---

<nav class="w-full border-b border-[--color-border] sticky top-0 z-40"
     style="background: var(--color-glass); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);">
  <div class="mx-auto max-w-[1280px] px-5 md:px-8 h-12 flex items-center justify-between">

    <a href="/" class="flex items-center gap-2 group">
      <span style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; font-size: 0.95rem;"
            class="text-[--color-text] group-hover:text-[--color-text] transition-colors duration-200">
        vugas<span style="color: var(--color-accent)">.</span>de
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-1">
      {navItems.map(({ href, label, num }) => (
        <li>
          <a
            href={href}
            class:list={[
              'inline-flex items-baseline gap-1.5 px-3 py-1.5 text-[0.68rem] uppercase transition-colors duration-200 rounded-full',
            ]}
            style="font-family: var(--font-display); letter-spacing: 0.08em;"
          >
            <span
              class:list={[
                'transition-colors duration-200',
                isActive(href) ? 'text-[--color-accent]' : 'text-[--color-text-soft] hover:text-[--color-accent]',
              ]}
            >
              {label}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <ul class="flex md:hidden items-center gap-4" style="font-family: var(--font-display); letter-spacing: 0.08em;">
      {navItems.slice(1).map(({ href, label }) => (
        <li>
          <a href={href} class:list={[
            'text-[0.66rem] uppercase transition-colors duration-200',
            isActive(href) ? 'text-[--color-accent]' : 'text-[--color-text-soft]',
          ]}>{label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>
