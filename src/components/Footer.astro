---
const year = new Date().getFullYear();
---

<footer class="border-t border-(--color-border) mt-24">
  <div class="mx-auto max-w-[1280px] px-5 md:px-8 py-10 grid grid-cols-1 md:grid-cols-[1.2fr_1fr_1fr_auto] gap-10">

    <div class="space-y-3">
      <div class="section-num mb-2">Lars Meykel Stuhlmacher</div>
      <p style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.03em;"
         class="text-[1.4rem] text-(--color-text) leading-none">
        vugas<span style="color: var(--color-accent)">.</span>de
      </p>
      <p class="text-[0.7rem] text-(--color-muted)"
         style="font-family: var(--font-display); letter-spacing: 0.08em; text-transform: uppercase;">
        &copy; {year} &mdash; self-hosted
      </p>
    </div>

    <div class="space-y-3">
      <div class="section-num mb-2">Contact</div>
      <ul class="space-y-1.5" style="font-family: var(--font-display); font-size: 0.78rem">
        <li><a class="arrow" href="mailto:contact@vugas.de">
          <span>contact@vugas.de</span><span class="glyph">&rarr;</span>
        </a></li>
        <li><a class="arrow" href="/rss.xml">
          <span>RSS / Log</span><span class="glyph">&rarr;</span>
        </a></li>
      </ul>
    </div>

    <div class="space-y-3">
      <div class="section-num mb-2">Stack</div>
      <p class="text-[0.7rem] text-(--color-muted) leading-relaxed"
         style="font-family: var(--font-display); letter-spacing: 0.06em; text-transform: uppercase;">
        Astro · Tailwind · Docker · Proxmox · OPNsense · nginx
      </p>
    </div>

    <div class="space-y-3 hidden md:block">
      <div class="section-num mb-2">Location</div>
      <p class="text-[0.66rem] text-(--color-muted-deep)"
         style="font-family: var(--font-mono); letter-spacing: 0.14em;">50.7374&deg;N / 7.0982&deg;E</p>
      <span class="live" style="font-size: 0.62rem;">ONLINE</span>
    </div>
  </div>

  <div class="border-t border-(--color-border)">
    <div class="mx-auto max-w-[1280px] px-5 md:px-8 h-10 flex items-center justify-between
                text-[0.66rem] tracking-[0.14em] uppercase text-(--color-muted-deep)"
         style="font-family: var(--font-display)">
      <span class="text-(--color-muted)">vugas.de &mdash; {year}</span>
      <span class="hidden sm:inline text-(--color-muted-deep)">Homelab &middot; Self-Hosting &middot; AI</span>
      <span class="flex items-center gap-4">
        <a href="/impressum" class="hover:text-(--color-text-soft) transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-(--color-text-soft) transition-colors">Datenschutz</a>
        <span class="live" style="font-size: 0.62rem;">SYSTEM</span>
      </span>
    </div>
  </div>
</footer>
