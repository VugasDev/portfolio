# Diese Datei dient nur der Dokumentation der erwarteten Variablen.
# Auf der VM wird die echte .env aus Bitwarden generiert:
#   Ordner 'portfolio-deploy', je Variable ein Item 'portfolio-<VAR>'
#   -> deploy/bw-sync-env.sh (bzw. deploy/refresh-secrets.sh)
# NICHT manuell mit echten Secrets befüllen.

WEBHOOK_SECRET=<openssl rand -hex 32; identisch zum GitHub-Webhook-Secret>
NEWT_ID=<von Pangolin Dashboard>
NEWT_SECRET=<von Pangolin Dashboard>
OAUTH_CLIENT_ID=<GitHub OAuth App Client ID>
OAUTH_CLIENT_SECRET=<GitHub OAuth App Client Secret>
ORIGINS=<erlaubte Origin(s) für den OAuth-Service, z.B. https://vugas.de>
REDIRECT_URL=<OAuth Redirect-URL, z.B. https://vugas.de/admin/>
